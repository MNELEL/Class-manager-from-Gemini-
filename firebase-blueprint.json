{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "ClassroomConfig": {
      "title": "ClassroomConfig",
      "description": "Classroom layout and student data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "rows": { "type": "number" },
        "cols": { "type": "number" },
        "grid": { "type": "array" },
        "students": { "type": "array" },
        "hiddenDesks": { "type": "array" },
        "rowGaps": { "type": "array" },
        "columnGaps": { "type": "array" },
        "teacherDesk": { "type": "object" },
        "groups": { "type": "array" },
        "furniture": { "type": "array" },
        "availableLessons": { "type": "array" },
        "updatedAt": { "type": "number" },
        "columnGapSize": { "type": "number" },
        "rowGapSize": { "type": "number" },
        "obstructions": { "type": "array" },
        "lockedDesks": { "type": "array" },
        "deskScales": { "type": "object" },
        "colSizes": { "type": "array" },
        "rowSizes": { "type": "array" },
        "events": { "type": "array" },
        "reminders": { "type": "array" },
        "campaigns": { "type": "array" },
        "rewards": { "type": "array" },
        "student_points": { "type": "object" },
        "attendance": { "type": "object" },
        "grades": { "type": "array" },
        "behaviorLog": { "type": "array" }
      },
      "required": ["id", "ownerId", "name", "rows", "cols", "grid", "students"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/configs/{configId}": {
      "schema": "ClassroomConfig",
      "description": "Classroom configurations"
    }
  }
}
