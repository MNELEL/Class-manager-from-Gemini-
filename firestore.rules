rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- CORE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATION ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.uid == request.auth.uid;
    }

    function isValidConfig(data) {
      // Basic keys check
      return data.keys().hasAll(['id', 'ownerId', 'name', 'rows', 'cols', 'grid', 'students']) &&
             data.id is string && data.id.size() <= 128 &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.rows is int && data.rows > 0 && data.rows <= 50 &&
             data.cols is int && data.cols > 0 && data.cols <= 50 &&
             data.grid is list && data.grid.size() <= 50 &&
             data.students is list && data.students.size() <= 200;
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isEmailVerified() && isValidUser(incoming());
      allow update: if isOwner(userId) && isEmailVerified() && isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt', 'configIds']);
    }

    match /configs/{configId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isEmailVerified() && isValidConfig(incoming()) && 
                       isValidId(configId) && configId == incoming().id;
      allow update: if isOwner(existing().ownerId) && isEmailVerified() && 
                       isValidConfig(incoming()) && 
                       incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
